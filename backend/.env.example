# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME="Kona Ice Invoice Automation"
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ───────────────────────────────────────────────────────────────
# Docker compose provides this automatically. For SQLite local dev use:
#   DATABASE_URL=sqlite:///./konaice.db
DATABASE_URL=postgresql+psycopg2://konaice:konaice@localhost:5432/konaice

# ─── Celery / Redis ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Run the pipeline inline in the API process instead of dispatching to Celery.
# Handy for local dev / SQLite. Set false to use the worker.
PIPELINE_RUN_INLINE=true

# ─── Seed admin user ────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@konaice.com
FIRST_ADMIN_PASSWORD=changeme

# ─── Pipeline safety ─────────────────────────────────────────────────────────
# true = compute everything but write NOTHING to the CRM (no draft create/
# delete, no event update). Recommended for first runs against production.
PIPELINE_DRY_RUN=false

# ─── Integration providers ───────────────────────────────────────────────────
# CRM_PROVIDER: mock | konaos (direct, in-process) | live (HTTP to deployed proxy)
CRM_PROVIDER=mock
SQUARE_PROVIDER=mock
OPENAI_PROVIDER=mock
SHEETS_PROVIDER=mock
TELEGRAM_PROVIDER=mock

# ─── Kona CRM via deployed proxy (CRM_PROVIDER=live) ────────────────────────
# KONA_CRM_TOKEN is sent as the X-API-Key header (the proxy's GPT_API_KEY).
KONA_CRM_BASE_URL=https://konaoscrmsapis-production.up.railway.app
KONA_CRM_TOKEN=

# ─── KonaOS direct (CRM_PROVIDER=konaos — merged Konaos_crms_apis code) ─────
# Also powers the /api/konaos/* endpoints and the API Explorer tab.
KONAOS_API_BASE_URL=https://api.konaos.com
KONAOS_EMAIL=
KONAOS_PASSWORD=
KONAOS_LOGIN_SECRET=
KONAOS_BRAND_IDS=
# Initial session key seed (jsessionId from admin.konaos.com devtools).
# Rotates ~every 15-30 days; a daily beat task refreshes/alerts, and a new key
# can be pasted at runtime via POST /api/konaos/session (API Explorer tab) —
# the persisted .konaos_session_cache.json then takes precedence over this.
KONAOS_SESSION_KEY=
# X-API-Key accepted by /api/konaos/* (dashboard JWTs are accepted too)
GPT_API_KEY=

# ─── Square (live) ──────────────────────────────────────────────────────────
SQUARE_API_BASE=https://connect.squareup.com
SQUARE_KONA_TOKEN=
SQUARE_TOM_TOKEN=

# ─── OpenAI (live) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
# $ per 1M tokens for cost tracking (update to current OpenAI pricing)
OPENAI_INPUT_COST_PER_MTOK=1.25
OPENAI_OUTPUT_COST_PER_MTOK=10.0

# ─── Google Sheets (live) ───────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
KONA_SHEET_ID=1tuLWnWQTHErp50ITvhkOMdBRZ4xDlruISPjMIZ_W-Z0
TOM_SHEET_ID=1ntLyVH37MQypG7nLpnd6JTsaCI4UP1VbN3vfXVzzZhs

# ─── Telegram (live) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
