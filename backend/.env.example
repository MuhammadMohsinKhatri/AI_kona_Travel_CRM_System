# ─── Kona Ice / Travelin' Tom — backend configuration ───────────────────────
# Copy to backend/.env and fill in. NEVER commit the filled-in file: .env is
# gitignored, this template is not.
#
# Telegram is NOT here any more — bot token and chat ids are configured in the
# app itself (Settings page) so they can be changed without a redeploy.

# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME="Conbyt AI Automation Financial System"
# development | production
ENVIRONMENT=development
# Signs dashboard login tokens. Generate a fresh one per environment:
#   openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Where the browser loads the dashboard from. In production this is your real
# https domain — a mismatch here is what makes the API "work in curl but not
# in the browser".
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ───────────────────────────────────────────────────────────────
# Local dev without Postgres:  sqlite:///./konaice.db
# Docker (prod stack):         postgresql+psycopg2://konaice:konaice@db:5432/konaice
DATABASE_URL=sqlite:///./konaice.db

# ─── Celery / Redis ─────────────────────────────────────────────────────────
# Docker hostnames are `redis`; outside Docker use localhost.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# true  = run the pipeline inside the API process (local dev, no worker needed)
# false = dispatch to the Celery worker.
# MUST be false in production: the nightly 11:30 PM run and the daily cash /
# session checks are Celery beat schedules, and with `true` there is no beat,
# so nothing scheduled ever fires.
PIPELINE_RUN_INLINE=true

# ─── Seed admin login ───────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@konaice.com
FIRST_ADMIN_PASSWORD=changeme

# ─── Pipeline safety ────────────────────────────────────────────────────────
# true = compute and store everything, but write NOTHING to KonaOS (no invoice
# drafts, no event updates). The run log reports what it WOULD have done.
# Start here on any new deployment and only switch to false after reading a
# real run log.
PIPELINE_DRY_RUN=false

# ─── Integration providers ──────────────────────────────────────────────────
# mock = realistic sample data, no external calls, no credentials needed.
CRM_PROVIDER=mock
SQUARE_PROVIDER=mock
OPENAI_PROVIDER=mock

# ─── KonaOS (CRM_PROVIDER=konaos) ───────────────────────────────────────────
# Also powers the /api/konaos/* endpoints, the API Explorer tab and the New
# Event form.
KONAOS_API_BASE_URL=https://api.konaos.com
KONAOS_EMAIL=
KONAOS_PASSWORD=
KONAOS_LOGIN_SECRET=
KONAOS_BRAND_IDS=
# Session seed (jsessionId from admin.konaos.com devtools). Rotates every
# ~15-30 days; a daily task refreshes it and raises an alert if it can't. A
# fresh key can be pasted at runtime from API Explorer → KonaOS Session, and
# the persisted cache then takes precedence over this value.
KONAOS_SESSION_KEY=
# X-API-Key accepted by /api/konaos/* AND by the cash/fields endpoints your
# automations post to. Dashboard login tokens are accepted too.
GPT_API_KEY=

# ─── Square ─────────────────────────────────────────────────────────────────
# Kona and Tom's are SEPARATE Square accounts — one token each.
SQUARE_API_BASE=https://connect.squareup.com
SQUARE_KONA_TOKEN=
SQUARE_TOM_TOKEN=
SQUARE_KONA_LOCATION=LGYP8DB54HMPV
SQUARE_TOM_LOCATION=LGWPJYFHY9AJD

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# gpt-5-mini is the cost/accuracy sweet spot here. Events created through the
# New Event form skip the LLM entirely (rule-based classifier, $0).
OPENAI_MODEL=gpt-5-mini
# $ per 1M tokens, for the AI cost figure on the Dashboard.
OPENAI_INPUT_COST_PER_MTOK=0.25
OPENAI_OUTPUT_COST_PER_MTOK=2.0
