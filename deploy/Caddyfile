# Caddy reverse proxy with automatic HTTPS.
#
# Set DOMAIN in deploy/.env.caddy (or the shell) before `docker compose up`:
#   DOMAIN=ops.example.com   -> serves https://ops.example.com with auto TLS
#   DOMAIN=:80               -> plain HTTP on the VPS IP (no domain yet)
{$DOMAIN::80} {
    encode gzip

    # Everything goes to the frontend nginx, which serves the SPA and
    # proxies /api, /health, /openapi.json and /docs to the backend.
    reverse_proxy frontend:80
}
